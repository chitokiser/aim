/missions/* /missions 302
/api/offerwall/* https://ai119-bot-production.up.railway.app/api/offerwall/:splat 200
/api/earnwall/* https://ai119-bot-production.up.railway.app/api/earnwall/:splat 200

# Products registered after the last build aren't in generateStaticParams() yet.
# Netlify only applies this rule when no matching static file exists, so
# pre-built product pages are served directly; unknown IDs fall back to the
# "_" shell, which then fetches the real product client-side via useParams().
/shop/:id /shop/_/index.html 200
