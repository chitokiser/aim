PORT=3001
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-key-here

# One-time admin bootstrap secret (used at POST /api/auth/bootstrap)
# Set a strong random value; delete or leave blank after first admin is created
SETUP_SECRET=change-me-before-deploy

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=YourBot
TELEGRAM_GROUP_ID=-100123456789
MINI_APP_URL=https://t.me/YourBot/app
# Your personal Telegram numeric ID — receive admin alerts from the bot (get from @userinfobot)
ADMIN_TELEGRAM_ID=your-telegram-numeric-id

# TON payments — platform wallet address; users send with their Telegram ID as memo
TON_WALLET_ADDRESS=your-ton-wallet-address
# TonCenter API key (optional — increases rate limit from 1 to 10 req/s)
TONCENTER_API_KEY=

# USDT (TRC20) payments — users register their TRON wallet via /wallet bot command
USDT_WALLET_ADDRESS=your-tron-wallet-address
# Trongrid API key (optional — free tier: 15 req/s without key)
TRONGRID_API_KEY=

# ElevenLabs Text-to-Speech
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Second bot placed inside advertiser groups to track join/leave events
# Get token from @BotFather — this bot must be added as admin to each advertiser group
REWARD_BOT_TOKEN=your-reward-bot-token

# MatchAI BizMatch Bot — AI people-matching Telegram bot (@MatchAI_BizMatch_Bot)
BIZMATCH_BOT_TOKEN=your-bizmatch-bot-token

# Gemini — primary AI provider for BizMatch bot scoring/synthesis (OpenAI-compatible endpoint)
GEMINI_API_KEY=your-gemini-api-key
# OpenAI — fallback AI provider, used only if GEMINI_API_KEY is not set
OPENAI_API_KEY=your-openai-api-key

# Web search APIs — at least one enables real candidate search
# Tavily: https://tavily.com
TAVILY_API_KEY=
# Serper (Google Search): https://serper.dev
SERPER_API_KEY=

# Anthropic Claude — used for music-video storyboard analysis
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mureka AI Music Generation — https://platform.mureka.ai
MUREKA_API_KEY=your-mureka-api-key

# CPX Research Survey Monetization — https://www.cpx-research.com
# Get App ID and Secure Key from your CPX Research publisher dashboard
CPX_APP_ID=your-cpx-app-id
CPX_SECURE_KEY=your-cpx-secure-key
# Postback URL to register in CPX dashboard (replace with your Railway backend URL):
# https://YOUR_BACKEND/api/cpx/postback?trans_id={trans_id}&user_id={user_id}&amount_local={amount_local}&status={status}&hash={hash}

# Offerwall.me Monetization — https://offerwall.me
OFFERWALL_APP_ID=your-offerwall-app-id
OFFERWALL_API_KEY=your-offerwall-api-key
OFFERWALL_SECRET_KEY=your-offerwall-secret-key
# Postback URL to set in offerwall.me dashboard:
# https://ai119.netlify.app/api/offerwall/postback
