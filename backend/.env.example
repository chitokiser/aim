PORT=3001
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-key-here

# One-time admin bootstrap secret (used at POST /api/auth/bootstrap)
# Set a strong random value; delete or leave blank after first admin is created
SETUP_SECRET=change-me-before-deploy

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional — defaults to `${FIREBASE_PROJECT_ID}.firebasestorage.app` if unset.
# Set explicitly if your bucket was provisioned under a different name.
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=YourBot
TELEGRAM_GROUP_ID=-100123456789
MINI_APP_URL=https://t.me/YourBot/app
# Your personal Telegram numeric ID — receive admin alerts from the bot (get from @userinfobot)
ADMIN_TELEGRAM_ID=your-telegram-numeric-id

# TON payments — platform wallet address; users send with their Telegram ID as memo
TON_WALLET_ADDRESS=your-ton-wallet-address
# TonCenter API key (optional — increases rate limit from 1 to 10 req/s)
TONCENTER_API_KEY=

# USDT (TRC20) payments — users register their TRON wallet via /wallet bot command
USDT_WALLET_ADDRESS=your-tron-wallet-address
# Trongrid API key (optional — free tier: 15 req/s without key)
TRONGRID_API_KEY=

# Cartesia Text-to-Speech
CARTESIA_API_KEY=your-cartesia-api-key

# Second bot placed inside advertiser groups to track join/leave events
# Get token from @BotFather — this bot must be added as admin to each advertiser group
REWARD_BOT_TOKEN=your-reward-bot-token

# MatchAI BizMatch Bot — AI people-matching Telegram bot (@MatchAI_BizMatch_Bot)
BIZMATCH_BOT_TOKEN=your-bizmatch-bot-token

# Gemini — primary AI provider for BizMatch bot scoring/synthesis (OpenAI-compatible endpoint)
GEMINI_API_KEY=your-gemini-api-key
# OpenAI — fallback AI provider, used only if GEMINI_API_KEY is not set
OPENAI_API_KEY=your-openai-api-key

# Web search APIs — at least one enables real candidate search
# Tavily: https://tavily.com
TAVILY_API_KEY=
# Serper (Google Search): https://serper.dev
SERPER_API_KEY=

# Anthropic Claude — used for music-video storyboard analysis
ANTHROPIC_API_KEY=your-anthropic-api-key

# Pexels — free stock photos for webzine cover images, tried BEFORE Pixabay
# (real photos preferred over AI-generated ones for factual reference topics;
# also avoids Imagen's daily quota). Free key: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# Pixabay — secondary free stock photo source, tried if Pexels has no match.
# Free key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-api-key

# Mureka AI Music Generation — https://platform.mureka.ai
MUREKA_API_KEY=your-mureka-api-key

# CPX Research Survey Monetization — https://www.cpx-research.com
# Get App ID and Secure Key from your CPX Research publisher dashboard
CPX_APP_ID=your-cpx-app-id
CPX_SECURE_KEY=your-cpx-secure-key
# Postback URL to register in CPX dashboard (replace with your Railway backend URL):
# https://YOUR_BACKEND/api/cpx/postback?trans_id={trans_id}&user_id={user_id}&amount_local={amount_local}&status={status}&hash={hash}

# Offerwall.me Monetization — https://offerwall.me
OFFERWALL_APP_ID=your-offerwall-app-id
OFFERWALL_API_KEY=your-offerwall-api-key
OFFERWALL_SECRET_KEY=your-offerwall-secret-key
# Postback URL to set in offerwall.me dashboard:
# https://ai119.netlify.app/api/offerwall/postback

# EarnWall Offerwall — https://earnwall.net (App: AI119 OfferWall)
EARNWALL_SECRET_KEY=your-earnwall-secret-key
# Postback URL registered in EarnWall dashboard:
# https://ai119.netlify.app/api/earnwall/postback
# Required GET params (sent by EarnWall): subId, transId, reward, status, offer_name, signature
# signature = MD5(subId + transId + reward + EARNWALL_SECRET_KEY)

# Paymentwall — https://paymentwall.com (Project ID: 530638)
PAYMENTWALL_PUBLIC_KEY=your-paymentwall-public-key
PAYMENTWALL_SECRET_KEY=your-paymentwall-secret-key
# Widget code from Paymentwall dashboard (Settings → Widgets → p1_1 or similar)
PAYMENTWALL_WIDGET=p1_1
# Pingback URL to set in Paymentwall dashboard (Settings → Pingback URL):
# https://ai119-bot-production.up.railway.app/api/paymentwall/pingback

# CJ Dropshipping — https://developers.cjdropshipping.com
# Get this from CJ Dropshipping dashboard: My CJ → Authorize → APIStores
CJ_DROPSHIPPING_API_KEY=your-cj-dropshipping-api-key

# IndexNow — instant crawl notification for Bing/Yandex/Naver on new blog posts
# Any random hex string works; the SAME value must exist as the content of
# frontend/public/<key>.txt (already committed) so search engines can verify it.
INDEXNOW_KEY=your-indexnow-key

# Google Blogger — cross-posts blog articles by category, each to its own dedicated
# Blogger blog + OAuth project (isolates quota/write-block issues per blog).
# One-time setup per target: run `python bots/setup_blogger_auth.py` with a Desktop-app
# client_secret.json from a Google Cloud project (Blogger API v3 enabled) to get the
# CLIENT_ID/SECRET/REFRESH_TOKEN. BLOG_ID is the numeric ID in the Blogger dashboard
# URL: blogger.com/blog/posts/<BLOG_ID>
BLOGGER_TRENDING_CLIENT_ID=your-blogger-oauth-client-id.apps.googleusercontent.com
BLOGGER_TRENDING_CLIENT_SECRET=your-blogger-oauth-client-secret
BLOGGER_TRENDING_REFRESH_TOKEN=your-blogger-refresh-token
BLOGGER_TRENDING_BLOG_ID=your-blogger-blog-id

BLOGGER_CLASSICS_CLIENT_ID=your-blogger-oauth-client-id.apps.googleusercontent.com
BLOGGER_CLASSICS_CLIENT_SECRET=your-blogger-oauth-client-secret
BLOGGER_CLASSICS_REFRESH_TOKEN=your-blogger-refresh-token
BLOGGER_CLASSICS_BLOG_ID=your-blogger-blog-id

# Separate Google account/Cloud project from the two above (whose write access
# is blocked) — used only for the "silver-ai-bootcamp" category.
BLOGGER_SILVER_CLIENT_ID=your-blogger-oauth-client-id.apps.googleusercontent.com
BLOGGER_SILVER_CLIENT_SECRET=your-blogger-oauth-client-secret
BLOGGER_SILVER_REFRESH_TOKEN=your-blogger-refresh-token
BLOGGER_SILVER_BLOG_ID=your-blogger-blog-id

# WordPress.com site + OAuth2 app (isolates quota/write-block issues per site).
# One-time setup per target: register an app at developer.wordpress.com/apps/,
# then run the OAuth2 authorization-code flow (see README/CLAUDE.md) to get an
# ACCESS_TOKEN — WordPress.com tokens do not expire, so no refresh token is needed.
# SITE is the site ID or domain, e.g. your-blog.wordpress.com
WORDPRESS_TRENDING_SITE=your-trending-blog.wordpress.com
WORDPRESS_TRENDING_ACCESS_TOKEN=your-wordpress-access-token

WORDPRESS_CLASSICS_SITE=your-classics-blog.wordpress.com
WORDPRESS_CLASSICS_ACCESS_TOKEN=your-wordpress-access-token

# WordPress.com "buddhist" target: classics posts tagged 불교철학 only (see
# seed-buddhist-philosophy.ts) — routed to their own dedicated site instead of
# WORDPRESS_CLASSICS_SITE. If the same WordPress.com account owns both sites,
# the classics ACCESS_TOKEN can usually be reused here (scope=global covers
# every site the account owns) rather than running the OAuth flow again.
WORDPRESS_BUDDHIST_SITE=your-buddhist-blog.wordpress.com
WORDPRESS_BUDDHIST_ACCESS_TOKEN=your-wordpress-access-token

# Tumblr API (OAuth 1.0a app credentials) — register at https://www.tumblr.com/oauth/apps
TUMBLR_CONSUMER_KEY=your-tumblr-consumer-key
TUMBLR_CONSUMER_SECRET=your-tumblr-consumer-secret
# Per-blog OAuth 1.0a access token, obtained via bots/setup_tumblr_auth.py
TUMBLR_ACCESS_TOKEN=your-tumblr-oauth-token
TUMBLR_ACCESS_TOKEN_SECRET=your-tumblr-oauth-token-secret
TUMBLR_BLOG_NAME=your-blog.tumblr.com

# Facebook Graph API (Page posting) — register at https://developers.facebook.com/apps
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_LOGIN_CONFIG_ID=your-facebook-login-configuration-id
# Page ID + long-lived Page Access Token, obtained via bots/setup_facebook_auth.py
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
