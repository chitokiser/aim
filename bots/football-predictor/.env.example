# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789,987654321

# Anthropic API key for AI match analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# football-data.org API key (free tier at football-data.org)
FOOTBALL_API_KEY=your_football_data_org_key_here

# The Odds API key (free tier: 500 req/month — https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# JWT secret — must match JWT_SECRET in backend/.env for auto-login to work
JWT_SECRET=your_jwt_secret_here

# X (Twitter) API credentials — app must have Read+Write permission
# Get from: developer.twitter.com → your app → Keys and Tokens
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# SQLite (default) or PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///football_predictor.db

# Timezone for match time display (default: Asia/Seoul)
TIMEZONE=Asia/Seoul

# P (free points) awarded per daily claim (default: 10000)
DAILY_P=10000

# P bonus on first /start (default: 10000)
WELCOME_BONUS_P=10000

# Telegram group chat ID for broadcast messages (e.g. -1001234567890)
GROUP_CHAT_ID=-100xxxxxxxxxx
