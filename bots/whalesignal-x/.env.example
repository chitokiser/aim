# WhaleSignal X — Environment Variables
# Copy this file to .env and fill in real values

# === REQUIRED ===
WHALASIGNAL_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Must match JWT_SECRET in the AIM backend (backend/.env)
JWT_SECRET=aim-secret-key

# === ADMIN ===
# Comma-separated Telegram user IDs for admin access
ADMIN_IDS=123456789,987654321

# === DATABASE ===
# SQLite (default, for local dev):
DATABASE_URL=sqlite+aiosqlite:///whalesignal.db
# PostgreSQL (for Railway production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# === OPTIONAL — DATA SOURCES ===
# GitHub API (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=ghp_your_github_token_here

# CoinGecko API key (free tier at coingecko.com)
COINGECKO_API_KEY=CG-your_key_here

# CryptoRank API key (for funding data)
CRYPTORANK_API_KEY=your_cryptorank_key_here

# NewsAPI key (newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# === REDIS (optional, for caching) ===
# REDIS_URL=redis://localhost:6379

# === GROUP BROADCAST ===
# Telegram group/channel chat ID for twice-daily live broadcasts
# Get it by adding @userinfobot to the group, or via /stats command
GROUP_CHAT_ID=-1001234567890
# The bot's @username (without @), used for the "Start Bot" button in group messages
BOT_USERNAME=WhaleSignalXBot
# Broadcast schedule (UTC hour, 0-23)
GROUP_BROADCAST_MORNING_HOUR=9
GROUP_BROADCAST_EVENING_HOUR=21
