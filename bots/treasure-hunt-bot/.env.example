# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram user IDs (comma-separated)
ADMIN_IDS=123456789

# Group chat ID to announce new treasures (get with @userinfobot — negative for groups)
GROUP_CHAT_ID=-1001234567890

# Groq API Key (free) — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# SQLite (default) or PostgreSQL connection string
DATABASE_URL=sqlite+aiosqlite:///./treasurehunt.db

# X (Twitter) API credentials — app must have Read+Write permission
# Get from: developer.twitter.com → your app → Keys and Tokens
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
