# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram user IDs (comma-separated)
ADMIN_IDS=123456789

# Group chat ID to announce new treasures (get with @userinfobot — negative for groups)
GROUP_CHAT_ID=-1001234567890

# Groq API Key (free) — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# Firebase / Firestore credentials (from Firebase console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nxxxx\n-----END RSA PRIVATE KEY-----\n"

# Threads (Meta) API credentials — free, requires Threads Professional account
# Setup: developers.facebook.com/docs/threads/get-started
THREADS_USER_ID=your_threads_user_id_here
THREADS_ACCESS_TOKEN=your_long_lived_access_token_here

# Google Blogger API — free with any Google account
# Run: python ../setup_blogger_auth.py  (one-time, locally)
# Then copy the printed values here
BLOGGER_CLIENT_ID=728877597651-xxxx.apps.googleusercontent.com
BLOGGER_CLIENT_SECRET=GOCSPX-xxxx
BLOGGER_REFRESH_TOKEN=your_refresh_token_here
# Find Blog ID at: blogger.com → select blog → URL contains /blog/posts/<BLOG_ID>
BLOGGER_BLOG_ID=your_blog_id_here

# Tumblr API — https://www.tumblr.com/oauth/apps
# Consumer Key/Secret: from app registration
# OAuth Token/Secret: from "Explore API" → Authenticate
TUMBLR_CONSUMER_KEY=your_consumer_key_here
TUMBLR_CONSUMER_SECRET=your_consumer_secret_here
TUMBLR_OAUTH_TOKEN=your_oauth_token_here
TUMBLR_OAUTH_SECRET=your_oauth_secret_here
# Your Tumblr blog name (e.g. "myblog" for myblog.tumblr.com)
TUMBLR_BLOG_NAME=your_blog_name_here
