# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram user IDs (comma-separated)
ADMIN_IDS=123456789

# Group chat ID to announce new treasures (get with @userinfobot — negative for groups)
GROUP_CHAT_ID=-1001234567890

# Groq API Key (free) — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# SQLite (default) or PostgreSQL connection string
DATABASE_URL=sqlite+aiosqlite:///./treasurehunt.db

# Threads (Meta) API credentials — free, requires Threads Professional account
# Setup: developers.facebook.com/docs/threads/get-started
# 1. Create Threads Professional account
# 2. Create Meta Developer App → Add Threads product
# 3. Generate long-lived access token
# 4. Get your numeric Threads User ID
THREADS_USER_ID=your_threads_user_id_here
THREADS_ACCESS_TOKEN=your_long_lived_access_token_here
