# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram user IDs (comma-separated)
ADMIN_IDS=123456789

# Groq API Key — 무료: https://console.groq.com
GROQ_API_KEY=gsk_...

# Groq model (llama-3.3-70b-versatile recommended)
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily Search API Key — 무료: https://tavily.com
TAVILY_API_KEY=tvly-...

# Alpha Vantage API Key (optional)
ALPHA_VANTAGE_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/moneyhunter

# Schedule hours (KST, 24h)
MORNING_HOUR=9
EVENING_HOUR=18
TIMEZONE=Asia/Seoul
